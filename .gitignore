# ── Build output ─────────────────────────────────────────────────────────────
orderbook_stream
build/
cmake-build-*/

# ── Compiled objects / libraries ─────────────────────────────────────────────
*.o
*.a
*.so
*.dylib
*.dll

# ── CMake generated files (NOT the hand-crafted Makefile) ────────────────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CMakeScripts/
*.cmake

# ── ImGui generated ini (do not track window layout) ─────────────────────────
imgui.ini

# ── ImGui vendored source — large, pull separately ───────────────────────────
imgui/

# ── Protobuf generated files (regenerate with protoc from .proto sources) ────
proto/*.pb.cc
proto/*.pb.h

# ── Credentials & API keys — NEVER commit ────────────────────────────────────
.env
!.env.example
*api_key*
*api_secret*
*.pem
*.key
*id_rsa*
*id_ed25519*
config/secrets.*
credentials.*

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.clangd/
.clang-tidy
compile_commands.json

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
.directory
.Trash-*

# ── Logs & temp ───────────────────────────────────────────────────────────────
*.log
logs/
*.tmp
.cache/

# ── Backups ───────────────────────────────────────────────────────────────────
*.bak
*.backup
